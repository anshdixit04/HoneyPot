# Copy to infra/.env.prod on the VPS and edit there.

# Honeypot listener ports. Keep these non-privileged at first; map to 22/23
# only after you have moved SSH admin access to another port or VPN.
HONEYPOT_BIND_IP=0.0.0.0
HONEYPOT_SSH_PORT=2222
HONEYPOT_TELNET_PORT=2223

# Dashboard HTTP port. Put Caddy/Nginx/Cloudflare Tunnel in front of this for
# HTTPS if you attach a domain.
DASHBOARD_BIND_IP=0.0.0.0
DASHBOARD_HTTP_PORT=80

# Optional browser CORS allow-list for direct API access. Same-origin Nginx
# proxying does not need CORS, so this can stay empty.
ALLOWED_ORIGINS=
